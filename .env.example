# =========================
# Execução web (modo normal)
# =========================
AGHUSE_URL=https://...
USER_NAME=...
USER_PW=...
OPENAI_API_KEY=...

# Modelo / timeout do resumo
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT_SECONDS=120

# Servidor Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=8000

# =========================
# Modo fixture local
# =========================
# Quando definido, o sistema NÃO acessa o AGHUse.
# O valor deve apontar para um PDF bruto baixado do sistema.
EVOLUTION_FIXTURE_PATH=./meu-relatorio.pdf

# =========================
# Artefatos gerados
# =========================
PDF_OUTPUT_PATH=downloads/evolucoes-intervalo.pdf
TXT_OUTPUT_PATH=downloads/evolucoes-intervalo.txt
PROCESSED_TXT_OUTPUT_PATH=downloads/evolucoes-intervalo-processado.txt
SORTED_TXT_OUTPUT_PATH=downloads/evolucoes-intervalo-ordenado.txt
PDF_DEBUG_HTML_PATH=downloads/evolucoes-intervalo.debug.html

# =========================
# Execução manual via main.py
# =========================
PATIENT_REC_NUMBER=...

# =========================
# Execução manual via intervalo de datas
# =========================
# Usado em scripts legados/manuais que trabalham diretamente
# com o formato esperado pelo AGHUse.
INTERVAL_START_DATETIME=19/03/2026 00:01
INTERVAL_END_DATETIME=04/04/2026 23:59
